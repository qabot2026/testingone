# =============================================================================
# ES Chatbot — single config (copy to .env locally; same keys on Railway)
# Server reads via es_private/lib/app-env.js — no manual npm install needed
# (Cursor opens project → deps auto-install; Railway installs on deploy)
# =============================================================================

# --- Core (required) ---
PORT=4567
PUBLIC_BASE_URL=https://es-based-chatbot-production.up.railway.app
DIALOGFLOW_PROJECT_ID=recebot-ptav

# --- Google credentials (Railway: paste full JSON as one line) ---
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# --- Google Sheets ---
# SHEETS_SPREADSHEET_ID=
# SHEETS_RANGE=Sheet1!A:AG
# SHEETS_DASHBOARD_RANGE=Sheet2!A:M
# SHEETS_AGENT_TAB=Agent Chats
# SHEETS_CONV_DATETIME_TZ=Asia/Kolkata

# --- Google Cloud Storage ---
# GCS_BUCKET_NAME=your-bucket-name
# GCS_UPLOAD_PREFIX=user-uploads
# GCS_CHAT_ASSETS_PREFIX=bot-assets
# GCS_SIGNED_URL_DAYS=7
# Max file size for web chat, WhatsApp, Instagram, and Facebook uploads (default 15)
# MAX_UPLOAD_MB=15
# CONTACT_FORM_SUBMISSION_TZ=Asia/Kolkata
# Optional timezone for $greeting, $date, $time in Dialogflow bot text (default Asia/Kolkata)
# CHAT_TIMEZONE=Asia/Kolkata

# --- Live agent desk ---
# LIVE_AGENT_DESK_TOKEN=
# CONVERSATIONS_SHEET_VIEW_SECRET=

# --- Per-client files: es_public/client-based + es_private/client-based/data ---

# --- Auto-sync data + bot assets (config, settings, demo pages) to GCS + GitHub ---
# REQUIRED on Railway — without GITHUB_TOKEN, new bots stay on server only (not in git).
# 1. GitHub → Settings → Developer settings → Personal access tokens → repo scope
# 2. Railway → Variables → GITHUB_TOKEN=ghp_...
# 3. Redeploy (startup auto-pushes any bots missing from GitHub)
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=qabot2026/ES_01
# GITHUB_BRANCH=main
# GCS_DATA_SYNC_PREFIX=config-data
# DATA_SYNC_GCS=1
# DATA_SYNC_GITHUB=1

# --- Meta: WhatsApp, Instagram, Facebook (session IDs: wa- / ig- / fb-) ---
# WHATSAPP_TOKEN=
# WHATSAPP_APP_SECRET=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=your-custom-verify-string
# (aliases also work: WHATSAPP_ACCESS_TOKEN, META_APP_SECRET, META_VERIFY_TOKEN)
# FB_PAGE_ACCESS_TOKEN=          # Instagram + Facebook Messenger (see INSTAGRAM-FACEBOOK-PERMANENT-TOKEN-SETUP.md)
# INSTAGRAM_PAGE_ID=

# Webhook URL in Meta App Dashboard:
#   https://YOUR_PUBLIC_BASE_URL/webhooks/meta

# --- Optional ---
# DIALOGFLOW_ALLOWED_PROJECTS=
# APPOINTMENT_TIMEZONE=Asia/Kolkata
# NODE_ENV=production
