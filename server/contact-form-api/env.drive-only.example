# Files only — copy variable names into Railway (values are examples).
#
# Option A — Apps Script web app (simple for personal Gmail; script runs as you):
# DRIVE_ONLY=1
# GOOGLE_APPS_SCRIPT_WEBAPP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
#
# Option B — Drive API + service account (folder must be on a Workspace *Shared drive*):
# DRIVE_ONLY=1
# GOOGLE_DRIVE_FOLDER_ID=1abcDEFghIJKlmnOPqRS_tuvwxyZ

DRIVE_ONLY=1
GOOGLE_APPS_SCRIPT_WEBAPP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Optional: calendar date in folder names uses this IANA zone (default UTC). Example: Asia/Kolkata
# CONTACT_FORM_SUBMISSION_TZ=Asia/Kolkata

# If you still use Firestore or Google Sheets via this API, keep your service-account JSON:
# FIREBASE_SERVICE_ACCOUNT_JSON=...   OR   GOOGLE_SERVICE_ACCOUNT_JSON=...
# Apps Script uploads alone do not require it.
