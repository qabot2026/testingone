{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "rootDirectory": ".",
    "dockerfilePath": "server/chatbot-api/Dockerfile",
    "watchPatterns": ["**", "railway.json", "api-base.config.js"]
  },
  "deploy": {
    "healthcheckPath": "/health",
    "startCommand": "node index.mjs"
  }
}
